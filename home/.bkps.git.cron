#!/bin/bash

bkpFolders=(
  $HOME/dotfiles
  $HOME/notes
  $HOME/private
  $HOME/code/arafatm/blinkist
)


for f in ${bkpFolders[@]}; do
  if [[ -d $f ]]; then
    echo "########################################"
    cd $f && echo $(pwd)
    git pull \
      && git add . \
      && git commit . -m "bkp" \
      && git push \
      >> $HOME/tmp/cron.log 2>&1
  fi
done

